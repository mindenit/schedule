{
	"name": "mindenit-schedule",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"prepare": "simple-git-hooks",
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prettier": "prettier --check .",
		"prettier:fix": "prettier --write .",
		"format": "pnpm prettier:fix && pnpm lint:fix",
		"typecheck": "nuxt typecheck",
		"deps:check": "taze -r",
		"deps:upgrade": "taze major -r -w && pnpm install"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged",
		"commit-msg": "pnpm commitlint --edit $1"
	},
	"lint-staged": {
		"*.{js,ts,vue,mjs,mts}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{json,yml,yaml,css,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@nuxt/a11y": "1.0.0-alpha.1",
		"@nuxt/eslint": "^1.16.0",
		"@nuxt/fonts": "0.14.0",
		"@nuxt/hints": "1.1.3",
		"@nuxt/icon": "^2.2.3",
		"@nuxt/scripts": "1.2.1",
		"@nuxtjs/color-mode": "^4.0.1",
		"@nuxtjs/seo": "^5.3.0",
		"@openpanel/nuxt": "^0.4.1",
		"@pinia/nuxt": "^0.11.3",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/query-persist-client-core": "^5.101.0",
		"@tanstack/vue-query": "^5.101.0",
		"@tanstack/vue-table": "^8.21.3",
		"@unhead/vue": "^2.0.3 || ^3.0.0",
		"@vueuse/core": "^14.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"date-fns-tz": "^3.2.0",
		"eslint": "^9.28.0",
		"idb-keyval": "^6.2.5",
		"motion-v": "^2.3.0",
		"nurekit": "^0.6.8",
		"nuxt": "^4.4.8",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.10",
		"satori": "^0.26.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"v-calendar": "^3.1.2",
		"vaul-vue": "^0.4.1",
		"vue": "^3.5.38",
		"vue-router": "^5.1.0",
		"vue-sonner": "^2.0.9"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@popperjs/core": "^2.11.8",
		"@yuta-inoue-ph/nuxt-vcalendar": "^1.1.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"lint-staged": "^17.0.8",
		"prettier": "^3.8.4",
		"prettier-plugin-classnames": "^0.10.2",
		"prettier-plugin-merge": "^0.10.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"simple-git-hooks": "^2.11.1",
		"typescript": "^5.8.3"
	},
	"packageManager": "pnpm@11.10.0+sha512.C3+LmAYAMZBMAX46QesYehbUDuuCm5XE+MsDaBdh/Eq1PdIZEVubRH9NzhoFohR2RGHn03AzkqnzL5URzoyGyA=="
}
