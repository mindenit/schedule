# Port exposed by the Node server / Docker container.
EXTERNAL_PORT=3000

# Set to "true" to enable maintenance mode (shows the /maintenance page).
MAINTENANCE=false

# Secret used to sign and verify OG image URLs.
# Required in production — the build fails fast if this is missing.
# Generate with: openssl rand -hex 32
NUXT_OG_IMAGE_SECRET=

# Client ID from your OpenPanel project settings.
NUXT_PUBLIC_OPENPANEL_CLIENT_ID=

# Base URL of your self-hosted OpenPanel API (include /api suffix).
# Example: https://analytics.example.com/api
NUXT_PUBLIC_OPENPANEL_API_URL=
